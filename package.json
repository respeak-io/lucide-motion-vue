{
  "name": "@respeak/lucide-motion-vue",
  "description": "Lucide icons animated with Motion for Vue — ergonomic animateOnHover, animateOnTap, animateOnView, and a composable <AnimateIcon> wrapper.",
  "version": "0.3.2",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "sideEffects": false,
  "files": [
    "dist",
    "ATTRIBUTIONS.md",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "vue",
    "vue3",
    "icons",
    "lucide",
    "motion",
    "motion-v",
    "animated-icons",
    "svg",
    "animate-ui"
  ],
  "author": "Respeak (https://respeak.io)",
  "contributors": [
    "Tim Rietz <tim.rietz@respeak.io>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/respeak-io/lucide-motion-vue.git"
  },
  "bugs": {
    "url": "https://github.com/respeak-io/lucide-motion-vue/issues"
  },
  "homepage": "https://respeak-io.github.io/lucide-motion-vue/",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.vue.d.ts",
      "import": "./dist/icons/*.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc -p tsconfig.lib.json --emitDeclarationOnly",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "docs:dev": "vite --config vite.docs.config.ts",
    "docs:build": "vite build --config vite.docs.config.ts",
    "docs:preview": "vite preview --config vite.docs.config.ts",
    "docs:hero": "node scripts/record-hero.mjs",
    "docs:social": "node scripts/record-social.mjs",
    "docs:closeup": "node scripts/record-closeup.mjs",
    "docs:captures": "pnpm docs:hero && pnpm docs:social && pnpm docs:closeup",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "motion-v": "^2",
    "vue": "^3.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "motion-v": "^2.2.1",
    "playwright": "^1.59.1",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "vite-plugin-vuetify": "^2.0.4",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0",
    "vuetify": "^3.7.6"
  }
}
